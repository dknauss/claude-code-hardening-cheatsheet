// ============================================================
// Allow examples for ~/.claude/settings.json
// ============================================================
// These are NOT included in settings-template.json because
// allow rules are environment-specific. Pick what fits your
// workflow and merge into your settings.json.
//
// Note: With "autoAllowBashIfSandboxed": true, Bash commands
// are already auto-allowed inside the sandbox. These explicit
// allows are useful when sandbox is disabled or for non-Bash
// tools (Read, MCP, etc.).
// ============================================================
{
  "permissions": {
    "allow": [
      // ── Test & Build ──
      // Frequently used commands — skip the permission prompt
      "Bash(npm test *)",
      "Bash(npm run build *)",
      "Bash(npm run lint *)",
      "Bash(pytest *)",
      "Bash(go test *)",
      "Bash(cargo test *)",
      "Bash(make *)",

      // ── Git (safe read-only operations) ──
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",

      // ── MCP: Read-only actions ──
      // Allow reading while denying sending/writing
      "mcp__claude_ai_Slack__slack_list_channels",
      "mcp__claude_ai_Slack__slack_get_channel_history",
      "mcp__claude_ai_Slack__slack_get_thread_replies",
      "mcp__claude_ai_Slack__slack_get_users",
      "mcp__claude_ai_Slack__slack_search_messages",
      "mcp__claude_ai_Google_Calendar__gcal_list_events",
      "mcp__claude_ai_Google_Calendar__gcal_list_calendars",
      "mcp__claude_ai_Google_Calendar__gcal_get_event"
    ]
  }
}
